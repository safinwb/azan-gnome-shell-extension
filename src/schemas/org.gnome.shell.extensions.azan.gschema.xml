<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="gnome-shell-extensions">
  <schema path="/org/gnome/shell/extensions/azan/" id="org.gnome.shell.extensions.azan">

    <key type="s" name="calculation-method">
        <default>"MWL"</default>
        <summary>Calculation method</summary>
        <description>Calculation method</description>
    </key>

    <key type="s" name="madhab">
        <default>"Standard"</default>
        <summary>Madhab</summary>
        <description>Madhab for calculating Asr time</description>
    </key>

    <key type="b" name="auto-location">
        <default>true</default>
        <summary>Automatic location</summary>
        <description>Whether or not to use GeoClue2 to detect the location</description>
    </key>

    <key type="d" name="latitude">
        <default>34.8406</default>
        <summary>Latitude</summary>
        <description>Latitude of your location</description>
    </key>

    <key type="d" name="longitude">
        <default>10.7603</default>
        <summary>Longitude</summary>
        <description>Longitude of your location</description>
    </key>

    <key type="b" name="time-format-12">
        <default>false</default>
        <summary>AM/PM time format</summary>
        <description>Set time format to AM/PM hours</description>
    </key>

    <key type="s" name="timezone">
        <default>"auto"</default>
        <summary>Timezone</summary>
        <description>Timezone of your location</description>
    </key>
    
    <key type="d" name="hijri-date-adjustment">
        <default>0</default>
        <summary>Adjustment</summary>
        <description>Adjustment of the Hijri date</description>
    </key>

    <key type="s" name="concise-list">
      <default>"1"</default>
      <summary>Which times to show</summary>
    </key>

    <key type="s" name="language">
      <default>"english"</default>
      <summary>Language</summary>
      <description>Language for prayer time names (english or arabic)</description>
    </key>

    <key type="b" name="show-countdown">
      <default>true</default>
      <summary>Show countdown</summary>
      <description>Show remaining time countdown in the panel and next prayer section</description>
    </key>

    <key type="s" name="notifications">
      <default>"10and5"</default>
      <summary>Notifications</summary>
      <description>Choose when reminder notifications should appear</description>
    </key>

    <key type="i" name="test-notification-seq">
      <default>0</default>
      <summary>Test notification sequence</summary>
      <description>Increment to trigger a test notification from settings</description>
    </key>

    <key type="s" name="panel-position">
      <default>"center"</default>
      <summary>Panel position</summary>
      <description>Choose panel indicator position (left, center, or right)</description>
    </key>
  </schema>
</schemalist>
